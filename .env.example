# Copy to .env and fill in. README instructions have referenced this file
# since Phase 2; Phase 9 is the first phase that actually created it.

# Required
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional — GitHub Issues task queue (github_queue.py)
# GITHUB_TOKEN=ghp_your_token
# GITHUB_REPO=owner/repo

# Optional — Metricool social distribution (distributors/metricool.py)
# Drafts only by default; set NIL_AGENCY_AUTO_PUBLISH=1 to actually publish.
# METRICOOL_TOKEN=your_token
# METRICOOL_BLOG_ID=your_blog_id
# NIL_AGENCY_AUTO_PUBLISH=0

# Optional — orchestrator tuning (all have safe defaults)
# NIL_AGENCY_MODEL=claude-sonnet-4-6
# NIL_AGENCY_MAX_TOKENS=8096
# NIL_AGENCY_POLL_INTERVAL=60
# NIL_AGENCY_LOCK_TTL=900
# NIL_AGENCY_GIT_SYNC=0
# NIL_AGENCY_MAX_DAILY_SPEND_USD=15.0
